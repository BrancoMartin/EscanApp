# Configuracion opcional del entorno de IA.
# La app funciona sin este archivo: estos son los valores por defecto.

# Modelo base del que derivan los 9 modelos especializados.
# Tiene que coincidir con la directiva FROM de los Modelfiles.
OLLAMA_MODEL=qwen2.5:0.5b

# Servidor de Ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Cuanto tiempo mantiene Ollama cada modelo cargado en memoria tras usarlo.
AGENT_KEEP_ALIVE=30m
